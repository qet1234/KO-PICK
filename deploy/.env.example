POSTGRES_DB=kopick
POSTGRES_USER=kopick
POSTGRES_PASSWORD=replace-with-a-long-random-password

FRONTEND_URL=https://koreapick.duckdns.org
ALLOWED_ORIGINS=https://koreapick.duckdns.org

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REST_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

TOUR_API_SERVICE_KEY=
TOUR_API_MOBILE_APP=KoreaPick

JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ISSUER=KO-PICK
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=14d
KEYWORD_HASH_SALT=replace-with-a-random-private-value

COOKIE_SECURE=true
COOKIE_SAME_SITE=None
COOKIE_DOMAIN=
JAVA_TOOL_OPTIONS=-Xms64m -Xmx384m -XX:MaxMetaspaceSize=160m -XX:+UseSerialGC -Xss512k
