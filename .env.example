# Vercel / browser-safe public values
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_KAKAO_MAP_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase Edge Function secrets
# Register with: npx supabase secrets set KEY=value
TOUR_API_SERVICE_KEY=
TOUR_API_MOBILE_APP=KoreaPick
KAKAO_REST_API_KEY=

# Supabase automatically injects these into deployed Edge Functions.
# Local function serving can read them from supabase/.env.local.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OAuth provider credentials are entered in Supabase Dashboard > Authentication > Providers.
# Google: built-in provider
# Kakao: built-in provider
# Naver: custom OAuth2 provider identifier `custom:naver`
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
